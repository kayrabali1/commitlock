{
  "expo": {
    "name": "commitlock",
    "slug": "commitlock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "commitlock",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.commitlock.app",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.commitlock.app",
          "group.com.commitlock.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#06070B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06070B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set a profile picture.",
          "cameraPermission": "The app accesses your camera to let you take a profile picture."
        }
      ],
      [
        "expo-widgets",
        {
          "ios": {
            "src": "./src/widgets/ios"
          },
          "widgets": [
            {
              "name": "CommitmentsProgressWidget",
              "displayName": "Commitments Progress",
              "description": "Track your active commitments progress.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "CommitmentsProgressWidgetAndroid",
              "label": "Commitments Progress",
              "description": "Show your active commitments progress.",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      [
        "react-native-health",
        {
          "healthSharePermission": "Allow Commitlock to read your health data to verify your goals.",
          "healthUpdatePermission": "Allow Commitlock to save health and workout data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.commitlock.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.commitlock.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "d9781d4d-d532-46e8-abfe-6d532d39d0bd"
      }
    }
  }
}
